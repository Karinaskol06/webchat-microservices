POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=webchat_db
MONGO_INITDB_ROOT_USERNAME=mongoadmin
MONGO_INITDB_ROOT_PASSWORD=mongoadminpass
MONGO_INITDB_DATABASE=messages_db
REDIS_PASSWORD=redispass

# Eureka URL for BOTH docker-compose.discovery-service and JVM apps connecting via mapped port 8761
EUREKA_URL=http://localhost:8761/eureka/

JWT_SECRET=defaultSecretKeyForLocalDev
GATEWAY_INTERNAL_AUTH_TOKEN=local-gateway-token

# Password reset — Gmail SMTP (use an App Password: https://myaccount.google.com/apppasswords)
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_RATE_LIMIT_MAX=10
PASSWORD_RESET_RATE_LIMIT_WINDOW=1m
MAIL_ENABLED=true
MAIL_HEALTH_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=

DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=webchat_db

MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_USER=mongoadmin
MONGO_PASSWORD=mongoadminpass
MONGO_DB=messages_db
MONGO_AUTH_DB=admin

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redispass

SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=notification-service-local
KAFKA_TOPIC_MESSAGE_CREATED=chat.message.created.v1
KAFKA_TOPIC_MESSAGE_CREATED_DLQ=chat.message.created.v1.dlq

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@webchat.local

EUREKA_INSTANCE_HOSTNAME=localhost

#
# --- Ports (src/main/resources/application.yml defaults) ----------------------------
# discovery-service    8761
# user-service         8081
# auth-service         8082
# chat-service         8083
# notification-service 8084
# api-gateway          8089
#

